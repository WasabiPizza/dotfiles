[global]
    font = Roboto 11
    markup = full
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = right
    bounce_freq = 0
    show_age_threshold = 10
    word_wrap = yes
    ignore_newline = no
    geometry = "0x0-30+30"
    title = dunst
    class = dunst
    shrink = yes
    transparency = 0
    idle_threshold = 120
#    monitor = HDMI-A-0
    follow = none
    stack_duplicates = true
    hide_duplicate_count = true
    sticky_history = yes
    history_length = 10
    show_indicators = no
    line_height = 1
    notification_height = 0
    separator_height = 4
    padding = 15
    horizontal_padding = 25
    separator_color = auto
    browser = /usr/bin/chromium
    dmenu = /usr/bin/rofi
    icon_position = right
#    icon_path = /usr/share/icons/Papirus/32x32/status/:/usr/share/icons/Papirus/32x32/devices/
#    frame_width = 4
    frame_color = "#434C5E"
    corner_radius = 0
    max_icon_size=64

[shortcuts]
    close = ctrl+space
#   history = ctrl+i

[urgency_low]
    background = "#151821"
    foreground = "#ffffff"
    timeout = 10

[urgency_normal]
    background = "#151821"
    foreground = "#ffffff"
    timeout = 10

[urgency_critical]
    frame_color = "#ff0000"
    background = "#151821"
    foreground = "#ffffff"
    timeout = 60 
